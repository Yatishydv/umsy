{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/umsy.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"umsy.apk\""
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|umsy.apk).*)",
      "destination": "/index.html"
    }
  ]
}
