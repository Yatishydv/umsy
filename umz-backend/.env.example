# UMZ Backend - Environment Variables
# Copy this file to .env and fill in real values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/umz

# Server port
PORT=3001

# Frontend URL for CORS (update to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Gemini API key for AI Buddy (get one free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
